# Variáveis de ambiente para testes E2E
# Copie este arquivo para .env.test e preencha com suas credenciais de teste

# Supabase Configuration (use staging/test instance)
VITE_SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# SigiloPay Configuration (use test credentials)
SIGILOPAY_SECRET_KEY=your-sigilopay-secret-key-here
SIGILOPAY_WEBHOOK_SECRET=your-webhook-secret-here
SIGILOPAY_PUBLIC_KEY=your-public-key-here

# IMPORTANTE: Use credenciais de teste/staging, NUNCA credenciais de produção!
